diff --git a/.github/workflows/build-ios.yml b/.github/workflows/build-ios.yml
index 00d6574..9b95901 100644
--- a/.github/workflows/build-ios.yml
+++ b/.github/workflows/build-ios.yml
@@ -14,9 +14,16 @@ jobs:
       - name: 📥 Checkout
         uses: actions/checkout@v4
 
-      - name: 🛠 Select Xcode 26 (Swift 6.2+)
+      - name: 🛠 Select Xcode
         run: |
-          sudo xcode-select -s /Applications/Xcode_26.3.app/Contents/Developer
+          # List available Xcode versions
+          ls /Applications/Xcode*.app 2>/dev/null || true
+          # Select the latest available Xcode
+          LATEST=$(ls -d /Applications/Xcode*.app 2>/dev/null | sort -V | tail -1)
+          if [ -n "$LATEST" ]; then
+            echo "Selecting Xcode: $LATEST"
+            sudo xcode-select -s "$LATEST/Contents/Developer"
+          fi
           xcodebuild -version
           swift --version
 
@@ -25,6 +32,14 @@ jobs:
         run: |
           xcodebuild -list -project Steel.xcodeproj 2>&1 || true
 
+      - name: 🔨 Resolve Package Dependencies
+        working-directory: ios-steel
+        run: |
+          xcodebuild -resolvePackageDependencies \
+            -project Steel.xcodeproj \
+            -scheme Steel \
+            2>&1 || true
+
       - name: 🔨 Build Archive (no signing)
         working-directory: ios-steel
         run: |
@@ -45,7 +60,6 @@ jobs:
         run: |
           mkdir -p build/ipa-output/Payload
           
-          # Try multiple possible .app locations
           APP_PATH=""
           for candidate in \
             "build/Steel.xcarchive/Products/Applications/Steel.app" \
@@ -56,7 +70,6 @@ jobs:
             fi
           done
           
-          # Fallback: find any .app
           if [ -z "$APP_PATH" ]; then
             APP_PATH=$(find build/Steel.xcarchive -name "*.app" -type d 2>/dev/null | head -1)
           fi
diff --git a/.github/workflows/build.yml b/.github/workflows/build.yml
index 53fb210..e115178 100644
--- a/.github/workflows/build.yml
+++ b/.github/workflows/build.yml
@@ -13,21 +13,42 @@ jobs:
       - name: Checkout
         uses: actions/checkout@v4
 
-      - name: Setup Xcode
-        uses: maxim-lobanov/setup-xcode@v1
-        with:
-          xcode-version: '16.0'
+      - name: Select Xcode
+        run: |
+          LATEST=$(ls -d /Applications/Xcode*.app 2>/dev/null | sort -V | tail -1)
+          if [ -n "$LATEST" ]; then
+            echo "Selecting Xcode: $LATEST"
+            sudo xcode-select -s "$LATEST/Contents/Developer"
+          fi
+          xcodebuild -version
+          swift --version
+
+      - name: Resolve Packages
+        working-directory: ios-steel
+        run: |
+          xcodebuild -resolvePackageDependencies \
+            -project Steel.xcodeproj \
+            -scheme Steel \
+            2>&1 || true
 
       - name: Build
+        working-directory: ios-steel
         run: |
-          cd ios-steel
           xcodebuild build \
             -project Steel.xcodeproj \
             -scheme Steel \
-            -destination 'platform=iOS Simulator,name=iPhone 16,OS=18.0' \
+            -destination 'platform=iOS Simulator,name=iPhone 16,OS=latest' \
             -configuration Debug \
             CODE_SIGNING_ALLOWED=NO \
-            | xcpretty --color || true
+            2>&1 | tee build.log | xcpretty --color || true
+
+      - name: Upload Build Log
+        if: failure()
+        uses: actions/upload-artifact@v4
+        with:
+          name: build-log
+          path: ios-steel/build.log
+          retention-days: 7
 
       - name: Build Result
         if: always()
